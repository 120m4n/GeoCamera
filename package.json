{
  "name": "geocamera",
  "version": "1.0.0",
  "description": "PWA local-first para captura de fotos con metadatos geográficos",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "android": "npm run build && npx cap sync && npx cap open android",
    "ios": "npm run build && npx cap sync && npx cap open ios",
    "lint": "npx eslint src/",
    "icons": "open icons/generate-icons.html"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@capacitor-community/camera-preview": "^8.0.1",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "8.4.0",
    "leaflet": "^1.9.4",
    "open-location-code": "^1.0.3"
  }
}
